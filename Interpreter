import enum
import sys

# ==========================================
# 1. THE LEXER (Tokenization Engine)
# ==========================================
class TokenType(enum.Enum):
    DET_NINDA   = "DET_NINDA"   # {ninda}
    DET_IM      = "DET_IM"      # {im}
    DET_D       = "DET_D"       # {d}
    IDENTIFIER  = "IDENTIFIER"  # variable name
    ASSIGN      = "ASSIGN"      # =ba
    NUMBER      = "NUMBER"      # e.g., 42, 3.14
    STRING      = "STRING"      # e.g., "Inanna"
    PRINT       = "PRINT"       # .ibĝare
    EOF         = "EOF"

class Token:
    def __init__(self, type_: TokenType, value: str):
        self.type = type_
        self.value = value
    def __repr__(self):
        return f"Token({self.type.name}, '{self.value}')"

class Lexer:
    def __init__(self, source: str):
        self.source = source
        self.cursor = 0

    def error(self, msg="Drop clay error"):
        print(f"--- NU-ZU (Lexer Error): {msg} ---")
        sys.exit(1)

    def next_token(self) -> Token:
        while self.cursor < len(self.source):
            char = self.source[self.cursor]

            # Skip whitespace
            if char.isspace():
                self.cursor += 1
                continue

            # Skip comments
            if char == '/' and self.cursor + 1 < len(self.source) and self.source[self.cursor+1] == '/':
                while self.cursor < len(self.source) and self.source[self.cursor] != '\n':
                    self.cursor += 1
                continue

            # Determinatives: {ninda}, {im}, {d}
            if char == '{':
                end = self.source.find('}', self.cursor)
                if end == -1: self.error("Unmatched '{'")
                det_content = self.source[self.cursor+1:end]
                self.cursor = end + 1
                if det_content == "ninda": return Token(TokenType.DET_NINDA, "{ninda}")
                if det_content == "im":    return Token(TokenType.DET_IM, "{im}")
                if det_content == "d":     return Token(TokenType.DET_D, "{d}")
                self.error(f"Unknown divine/earthly class: {{{det_content}}}")

            # String Literals
            if char == '"':
                self.cursor += 1
                start = self.cursor
                while self.cursor < len(self.source) and self.source[self.cursor] != '"':
                    self.cursor += 1
                if self.cursor >= len(self.source): self.error("Unterminated text string record")
                str_val = self.source[start:self.cursor]
                self.cursor += 1 # Consume trailing quote
                return Token(TokenType.STRING, str_val)

            # Numeric Literals
            if char.isdigit() or char == '.':
                start = self.cursor
                while self.cursor < len(self.source) and (self.source[self.cursor].isdigit() or self.source[self.cursor] == '.'):
                    self.cursor += 1
                return Token(TokenType.NUMBER, self.source[start:self.cursor])

            # Operators, Builtins, and Identifiers
            if char.isalpha() or char in ['_', '=', '.']:
                start = self.cursor
                while self.cursor < len(self.source) and (self.source[self.cursor].isalnum() or self.source[self.cursor] in ['_', '=', '.', '-']):
                    self.cursor += 1
                lexeme = self.source[start:self.cursor]
                
                if lexeme == "=ba": return Token(TokenType.ASSIGN, "=ba")
                if lexeme == ".ibĝare": return Token(TokenType.PRINT, ".ibĝare")
                return Token(TokenType.IDENTIFIER, lexeme)

            self.error(f"Illegal cuneiform stroke: '{char}'")
            
        return Token(TokenType.EOF, "")

# ==========================================
# 2. THE ABSTRACT SYNTAX TREE (AST) NODES
# ==========================================
class ASTNode: pass

class VarAssignNode(ASTNode):
    def __init__(self, det_type: TokenType, var_name: str, value_node: ASTNode):
        self.det_type = det_type
        self.var_name = var_name
        self.value_node = value_node

class PrintNode(ASTNode):
    def __init__(self, var_name: str):
        self.var_name = var_name

class LiteralNode(ASTNode):
    def __init__(self, type_: TokenType, value: any):
        self.type = type_
        self.value = value

# ==========================================
# 3. THE PARSER & EVALUATOR (The Shuruppak Engine)
# ==========================================
class Interpreter:
    def __init__(self):
        # Memory ledger state tracking
        self.environment = {}
        self.constants = set()

    def error(self, err_type, msg):
        print(f"--- {err_type} ERROR: {msg} ---")
        sys.exit(1)

    def interpret(self, source_code: str):
        lexer = Lexer(source_code)
        tokens = []
        
        # Phase A: Tokenize completely
        token = lexer.next_token()
        while token.type != TokenType.EOF:
            tokens.append(token)
            token = lexer.next_token()
            
        # Phase B: Parse tokens into structured AST Nodes & Execute
        cursor = 0
        while cursor < len(tokens):
            tok = tokens[cursor]

            # Match variable creation pattern
            if tok.type in [TokenType.DET_NINDA, TokenType.DET_IM, TokenType.DET_D]:
                det_type = tok.type
                cursor += 1
                
                if cursor >= len(tokens) or tokens[cursor].type != TokenType.IDENTIFIER:
                    self.error("NU-ZU", "Expected a variable name following a type category marker.")
                var_name = tokens[cursor].value
                cursor += 1
                
                if cursor >= len(tokens) or tokens[cursor].type != TokenType.ASSIGN:
                    self.error("NU-ZU", f"Expected assignment operator '=ba' for entity '{var_name}'")
                cursor += 1
                
                if cursor >= len(tokens) or tokens[cursor].type not in [TokenType.NUMBER, TokenType.STRING]:
                    self.error("NU-ZU", "Expected a numerical quantity or literal text string value.")
                val_tok = tokens[cursor]
                
                # Cast the token's primitive values securely
                if val_tok.type == TokenType.NUMBER:
                    parsed_val = float(val_tok.value) if '.' in val_tok.value else int(val_tok.value)
                else:
                    parsed_val = val_tok.value
                    
                node = VarAssignNode(det_type, var_name, LiteralNode(val_tok.type, parsed_val))
                self.execute_assign(node)
                cursor += 1
                continue

            # Match direct output instruction
            if tok.type == TokenType.IDENTIFIER:
                var_name = tok.value
                cursor += 1
                if cursor < len(tokens) and tokens[cursor].type == TokenType.PRINT:
                    node = PrintNode(var_name)
                    self.execute_print(node)
                    cursor += 1
                    continue
                self.error("NU-ZU", f"Stray or unbound variable name pointer detected: '{var_name}'")

    def execute_assign(self, node: VarAssignNode):
        val = node.value_node.value
        
        # Strict Semantic Analysis / Guardrails
        if node.det_type == TokenType.DET_NINDA and not isinstance(val, (int, float)):
            self.error("NU-ZU", f"Type Violation. Category {{ninda}} strictly demands a structural float/integer, got '{val}'")
        if node.det_type == TokenType.DET_IM and not isinstance(val, str):
            self.error("NU-ZU", f"Type Violation. Category {{im}} strictly demands string data, got '{val}'")
            
        if node.var_name in self.constants:
            self.error("BALA", f"Sacrilege. The structural identity of Divine Constant '{node.var_name}' is locked by decree.")

        if node.det_type == TokenType.DET_D:
            self.constants.add(node.var_name)
            
        self.environment[node.var_name] = val

    def execute_print(self, node: PrintNode):
        if node.var_name not in self.environment:
            self.error("HUL", f"Null pointer memory fault. Variable '{node.var_name}' does not exist on this clay record.")
        print(self.environment[node.var_name])
